{
  "name": "bloom",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Bloom — an infinite Game of Life with an AssemblyScript engine",
  "scripts": {
    "asbuild": "asc assembly/field.ts --target release",
    "patterns": "node scripts/build-patterns.mjs",
    "dev": "vite",
    "build": "npm run asbuild && vite build",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "assemblyscript": "^0.27.31",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "solid-js": "^1.9.0"
  }
}
